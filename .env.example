# BAS Platform Environment Configuration
# =======================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ── API Server ──────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ── Database ────────────────────────────────
# SQLite (default, no extra setup needed)
DATABASE_URL=sqlite:///./bas_platform.db

# ── Sliver C2 Configuration ─────────────────
# Run 'sudo bash setup_sliver.sh' to generate the operator config
SLIVER_SERVER_HOST=127.0.0.1
SLIVER_SERVER_PORT=31337
SLIVER_CONFIG_PATH=/root/.sliver-client/configs

# ── Victim VM Credentials ───────────────────
# Used for WinRM / PowerShell remoting to the Windows victim VM
VICTIM_USERNAME=Administrator
VICTIM_PASSWORD=CHANGE_ME

# ── Safety Configuration ────────────────────
# Set to true ONLY in an isolated lab environment when ready for live attacks
LIVE_EXECUTION_ENABLED=false

# ── Network Whitelist ───────────────────────
# Comma-separated list of allowed target IPs (victim VM IPs only)
# Example: 192.168.56.101,192.168.56.102
ALLOWED_TARGETS=192.168.56.101

# ── Blocked Targets ─────────────────────────
# IPs that will NEVER be attacked (gateway, host, etc.)
BLOCKED_TARGETS=192.168.1.1,10.0.0.1

# ── Health Monitoring ───────────────────────
# Auto-stop attacks if victim health score drops below this (0-100)
HEALTH_THRESHOLD=30

# ── Telemetry ───────────────────────────────
# How often to collect metrics from the victim VM (seconds)
TELEMETRY_INTERVAL=5
